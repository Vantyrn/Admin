# ============================================================================
# Vantryn Admin (Next.js) — environment template
# Copy to .env (or .env.local) and fill in. NEVER commit the real file.
# Full setup: ../SETUP_CREDENTIALS.md
# ============================================================================

# ── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
RELEASE_VERSION=pilot-0.1.0

# ── Database (same Neon DB as the backend — ONE canonical schema) ────────────
DATABASE_URL=postgresql://USER:PASS@HOST-pooler.../neondb?sslmode=require

# ── Secrets (must match the backend) ─────────────────────────────────────────
ADMIN_SECRET=                  # MUST equal vantryn-server ADMIN_SECRET
JWT_SECRET=                    # admin JWT-cookie signing

# ── Backend (state/money actions are POSTed to the server) ───────────────────
NEXT_PUBLIC_BACKEND_URL=https://<backend-host>

# ── Observability ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=        # GlitchTip DSN (vantryn-admin project)
LOKI_URL=                      # central log sink (server-side only)
LOKI_USER=
LOKI_API_KEY=

# ── Google Maps (admin live map + vendor LocationPicker) — Tier 2 ────────────
# Enable BOTH "Maps JavaScript API" and "Geocoding API" on this key, or the
# vendor location picker shows ApiProjectMapError / Geocoder REQUEST_DENIED.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# RESERVED: a vector Map ID for a future migration to AdvancedMarkerElement.
# Not used yet — the maps currently use the classic (still-supported) Marker.
# Removing the deprecation warning needs ALL map loaders unified + this Map ID.
# NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# ── Cloudflare R2 (vendor KYC docs + logos upload) — Tier 2 ──────────────────
# NOTE: the Admin code (src/lib/cloudflare.js) reads these CLOUDFLARE_* names
# (NOT the R2_* names used by the backend). Until all four are set, document
# upload is skipped and KYC doc URLs save as null.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=
CLOUDFLARE_BUCKET_NAME=
CLOUDFLARE_R2_PUBLIC_URL=
